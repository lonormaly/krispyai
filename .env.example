# Copy to .env.local and fill in. Never commit real secrets.
#
# The lean self-host core is the edge Worker + the widget. The Worker's own secrets
# (TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID, TELEGRAM_WEBHOOK_SECRET, TENANT_SYNC_SECRET)
# live in Cloudflare, set with `wrangler secret put <NAME>` — NOT in this file.
#
# The vars below are only for the `krispy` CLI (packages/cli), which talks to a
# deployed Worker to manage your bot's knowledge base (system prompt).

# Your deployed edge Worker's base URL (default: http://localhost:8787 for wrangler dev).
KRISPY_API=http://localhost:8787

# Tenant id (single-tenant self-host: leave as "self").
KRISPY_TENANT=self

# Must match the Worker's TENANT_SYNC_SECRET (the one you `wrangler secret put`).
TENANT_SYNC_SECRET=

# ── Deploy creds (only for ./deploy.sh + the Tilt deploy:* resources) ──────────
# Fed from Infisical (docs/secrets.md §3). Preflight blocks the deploy if absent.
# Token scopes: Workers Scripts:Edit, Cloudflare Pages:Edit, Workers KV Storage:Edit.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional: deployed URLs for the post-deploy smoke check (per target × env).
# Leave unset to skip smoke on the first deploy. e.g. https://krispy-edge.you.workers.dev
# EDGE_PREVIEW_URL=
# EDGE_PRODUCTION_URL=
# DOCS_PREVIEW_URL=
# DOCS_PRODUCTION_URL=
# WIDGET_PREVIEW_URL=
# WIDGET_PRODUCTION_URL=
