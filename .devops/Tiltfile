# krispyai (public core) — local dev via Tilt + Vercel Portless.
#
# Every SERVED role (has a URL) is wrapped with portless so it gets a stable,
# named URL instead of a pinned port: <service>.krispy.localhost:1355.
# Portless injects a random PORT and proxies the named URL → that port, so
# NOTHING here pins a service port. Every served role reads process.env.PORT.
#
# The map: services/ = has a URL · packages/ = shared/static bundle. Only served
# roles get a Tilt resource; libs that are never served get none.
#
# This is the PUBLIC core — it stands alone (a cloner runs it without the private
# cloud repo). The cloud repo's dev.Tiltfile includes this one as a sibling.

os.putenv('PATH', os.environ['HOME'] + '/.bun/bin:' + os.environ.get('PATH', ''))

# Direct bun binary — bypasses any proto/moon shim that rewrites `bun run X`.
BUN = os.environ['HOME'] + '/.bun/bin/bun'

update_settings(max_parallel_updates=4)
docker_prune_settings(disable=True)

# Repo root (this Tiltfile lives in .devops/, loaded via load_dynamic from root).
REPO_ROOT = str(local('cd .. && pwd', quiet=True)).strip()

print('=' * 60)
print('KRISPYAI (public core) TILT - LOCAL (portless)')
print('=' * 60)

# All served roles share this scheme. <service>.krispy.localhost:1355
PORTLESS_PROXY = 'http://{}.krispy.localhost:1355'

# Sourced into each service so vars from .env.local reach the process. Cross-service
# URLs are injected AFTER this (via portless_cmd env=), so they win over stale values.
ENV_LOCAL = 'set -a && [ -f ' + REPO_ROOT + '/.env.local ] && . ' + REPO_ROOT + '/.env.local; set +a; '

# Portless wrapper: retry route registration with backoff to survive cross-project
# lock contention (portless has a ~1s internal lock budget; another project
# registering at the same moment can exceed it). Pass health_url to add a watchdog
# that kills the process group if the URL stops responding, so Tilt restarts it
# (fixes: portless stays alive while a --watch server silently loops on a crash).
def portless_cmd(args, env='', health_url=''):
    cmd = (env + ' ' if env else '') + 'portless --force ' + args
    retry = 'for i in 1 2 3 4 5 6 7 8; do ' + cmd + ' && break || echo "portless lock failed (attempt $i/8), retrying in 2s..." && sleep 2; done'
    if not health_url:
        return retry
    watchdog = '(sleep 20; FAILS=0; while true; do sleep 10; ' + 'if curl -sf -o /dev/null ' + health_url + ' 2>/dev/null; then FAILS=0; ' + 'else FAILS=$((FAILS+1)); echo "[watchdog] health check failed ($FAILS/3) for ' + health_url + '"; ' + 'if [ $FAILS -ge 3 ]; then echo "[watchdog] killing process group after 3 failed checks"; kill 0; exit 1; fi; ' + 'fi; done) &'
    # Wrap in { } so the backgrounded watchdog (&) doesn't break the parent shell.
    return '{ ' + watchdog + ' ' + retry + '; }'

# Fixed-port alias (adimoyal's proven pattern): the PROCESS owns a real port and
# `portless alias <name> <port>` just maps the named URL to it — NO portless
# --force random-port lock race (portless's ~1s lock budget vs wrangler's slow
# bind → "lock failed" → duplicate wranglers). `run` already contains the server's
# own --port/-l <port>; we prepend the alias + the kill-on-hang watchdog so Tilt
# restarts a wedged process. Use for wrangler and anything that owns its port.
def fixed_port_cmd(name, port, run, env='', health_url=''):
    alias = 'portless alias ' + name + ' ' + str(port) + ' || true; '
    serve = (env + ' ' if env else '') + run
    if not health_url:
        return alias + serve
    watchdog = '(sleep 20; FAILS=0; while true; do sleep 10; ' + 'if curl -sf -o /dev/null ' + health_url + ' 2>/dev/null; then FAILS=0; ' + 'else FAILS=$((FAILS+1)); echo "[watchdog] health check failed ($FAILS/3) for ' + health_url + '"; ' + 'if [ $FAILS -ge 3 ]; then echo "[watchdog] killing process group after 3 failed checks"; kill 0; exit 1; fi; ' + 'fi; done) &'
    return '{ ' + alias + watchdog + ' ' + serve + '; }'

# =============================================================================
# Services (served — have a URL, wrapped with portless)
# =============================================================================

# edge — the live-chat + human-handoff Worker (Hono-style routes + SessionDO), run
# under `wrangler dev`. Pinned to a FIXED port (8787) via the fixed-port pattern:
# wrangler OWNS the port (--port 8787), and portless just aliases edge.krispy to
# it. This removes the old `portless --force --port '$PORT'` random-port + retry
# loop, whose ~1s lock budget lost the race against wrangler's slow bind ("lock
# failed" → duplicate wranglers). --ip 127.0.0.1 keeps the bind local; the
# watchdog heals a hung wrangler so Tilt auto-restarts it. edge serves GET /health.
EDGE_PORT = 8787
local_resource(
    'edge',
    serve_cmd='cd ' + REPO_ROOT + '/services/edge && ' + ENV_LOCAL + fixed_port_cmd(
        'edge.krispy', EDGE_PORT,
        BUN + ' x wrangler dev --port ' + str(EDGE_PORT) + ' --ip 127.0.0.1',
        health_url='http://localhost:' + str(EDGE_PORT) + '/health'),
    links=['http://localhost:' + str(EDGE_PORT) + '/health', PORTLESS_PROXY.format('edge') + '/health'],
    labels=['services'],
)

# =============================================================================
# Packages (served static bundle — wrapped with portless)
# =============================================================================

# widget — the embeddable chat widget: a static index.html + widget.js bundle.
# Pinned to a FIXED port (3080) via the fixed-port pattern; `serve -l` owns the
# port and portless just aliases widget.krispy to it. Fixed avoids `serve`'s
# default :3000 (which collided with the cloud web app when portless didn't
# inject $PORT). Static server, no health route → no watchdog.
WIDGET_PORT = 3080
local_resource(
    'widget',
    serve_cmd='cd ' + REPO_ROOT + ' && ' + fixed_port_cmd(
        'widget.krispy', WIDGET_PORT,
        BUN + ' x serve packages/widget -l tcp://0.0.0.0:' + str(WIDGET_PORT)),
    links=['http://localhost:' + str(WIDGET_PORT), PORTLESS_PROXY.format('widget')],
    labels=['packages'],
)

# =============================================================================
# Deploy (MANUAL buttons — one per target × env). NOT auto-run: a deploy is a
# button you press, never something Tilt fires on file change. Each shells out to
# the SAME ./deploy.sh the CLI uses (DRY), which runs preflight → build → wrangler
# deploy → smoke. Cloudflare creds come from the Infisical-fed .env.local — nothing
# is hardcoded here, and no secret ever touches GitHub Actions.
# =============================================================================
def deploy_resource(target, env):
    local_resource(
        'deploy:' + target + '-' + env,
        cmd='cd ' + REPO_ROOT + ' && ./deploy.sh ' + target + ' ' + env,
        auto_init=False,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['deploy'],
    )

for target in ['edge', 'docs', 'widget']:
    for env in ['preview', 'production']:
        deploy_resource(target, env)

print("""
================================================================================
                    KRISPYAI (public core) LOCAL DEV (Portless)
================================================================================
  Edge:   http://localhost:8787  (or edge.krispy.localhost:1355)   (/health — wrangler dev)
  Widget: http://localhost:3080  (or widget.krispy.localhost:1355) (static embed bundle)

  No-Tilt path: `bun run dev:edge` + `bun run dev:widget` (two terminals).
  Portless proxy: install with `npm install -g portless` (starts automatically).
================================================================================
""")
