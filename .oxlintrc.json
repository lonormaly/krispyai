{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "options": {
    "typeAware": true
  },
  "rules": {
    "typescript/no-base-to-string": "warn"
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.next/**",
    "**/.source/**",
    "**/dist/**",
    "**/build/**"
  ]
}
