meta {
  name: Operator - resolve session
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/operator/resolve
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{operatorToken}}
}

body:json {
  {
    "tenantId": "self",
    "sessionId": "session-id-here"
  }
}

tests {
  test("responds 200", function() {
    expect(res.status).to.equal(200);
  });
  test("returns the toggled resolved state", function() {
    expect(res.getBody().ok).to.equal(true);
    expect(res.getBody().resolved).to.be.a("boolean");
  });
}

docs {
  Auth (in-Worker, enforced): send the operator app's bearer (`Authorization: Bearer
  <session token>` — verified against the cloud API's GET /me; the resolved user.id must
  equal `tenantId`, else 403) OR the server-to-server `x-tenant-sync-secret`. No/invalid
  credentials → 401. Verified bearers are cached in-isolate for 60s.

  Toggle a session's `resolved` flag (operator inbox hygiene). Resolving ALSO hands the
  session back to the AI: `handedOff` flips false and `{ type: "resume" }` is broadcast
  to the session's WebSockets, so the bot answers the visitor's next message. Resolved
  sessions are excluded from the default `/api/operator/handoffs` response; toggling
  again un-resolves (undo an accidental swipe) WITHOUT re-handing-off. A NEW live
  visitor message on a resolved session also un-resolves it automatically — the
  conversation is live again, answered by the AI. Missing `tenantId` or `sessionId`
  → 400. Response: `{ ok: true, resolved: boolean }` (the new state).
}
